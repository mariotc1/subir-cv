# Variables de entorno para CV Upload System
# Copiar este archivo a .env y modificar los valores

# Base de datos
DATABASE_URL=postgresql://cvapp:cvapp_secure_password@db:5432/cvapp

# JWT - IMPORTANTE: Cambiar en producción
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change_this_in_production_to_a_very_long_random_string

# Modo debug (false en producción)
DEBUG=false

# Directorio de uploads
UPLOAD_DIR=/app/storage/cvs
